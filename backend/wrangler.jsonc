{
  "name": "my-backend",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "ENVIRONMENT": "production"
  }
  // For production Postgres via Cloudflare Hyperdrive (optional but recommended):
  // "hyperdrive": [
  //   {
  //     "binding": "HYPERDRIVE",
  //     "id": "your-hyperdrive-id"
  //   }
  // ]
}